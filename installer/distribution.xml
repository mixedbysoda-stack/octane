<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="1">
    <title>Install OCTANE</title>
    <welcome    file="welcome.html"/>
    <license    file="license.html"/>
    <conclusion file="conclusion.html"/>
    <background          file="sidebar.png" alignment="bottomleft" scaling="proportional"/>
    <background-darkAqua file="sidebar.png" alignment="bottomleft" scaling="proportional"/>
    <options customize="never" require-scripts="false"/>
    <pkg-ref id="com.carbonatedaudio.octane.vst3.pkg"/>
    <pkg-ref id="com.carbonatedaudio.octane.au.pkg"/>
    <pkg-ref id="com.carbonatedaudio.octane.aax.pkg"/>
    <choices-outline>
        <line choice="default">
            <line choice="com.carbonatedaudio.octane.vst3.pkg"/>
            <line choice="com.carbonatedaudio.octane.au.pkg"/>
            <line choice="com.carbonatedaudio.octane.aax.pkg"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="com.carbonatedaudio.octane.vst3.pkg" visible="false"><pkg-ref id="com.carbonatedaudio.octane.vst3.pkg"/></choice>
    <choice id="com.carbonatedaudio.octane.au.pkg"   visible="false"><pkg-ref id="com.carbonatedaudio.octane.au.pkg"/></choice>
    <choice id="com.carbonatedaudio.octane.aax.pkg"  visible="false"><pkg-ref id="com.carbonatedaudio.octane.aax.pkg"/></choice>
    <pkg-ref id="com.carbonatedaudio.octane.vst3.pkg" version="1.0.0" onConclusion="none">OCTANE-VST3.pkg</pkg-ref>
    <pkg-ref id="com.carbonatedaudio.octane.au.pkg"   version="1.0.0" onConclusion="none">OCTANE-AU.pkg</pkg-ref>
    <pkg-ref id="com.carbonatedaudio.octane.aax.pkg"  version="1.0.0" onConclusion="none">OCTANE-AAX.pkg</pkg-ref>
</installer-gui-script>
